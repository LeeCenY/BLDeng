default_platform(:mac)

# Path to an App Store Connect API key config (JSON with key_id, issuer_id,
# key). Set ASC_API_KEY_PATH in the gitignored fastlane/.env (fastlane loads
# it automatically) or export it before invoking fastlane.
API_KEY_PATH = ENV["ASC_API_KEY_PATH"]

platform :mac do
  desc "Upload screenshots to App Store Connect"
  lane :upload_screenshots do
    deliver(
      api_key_path: API_KEY_PATH,
      platform: "osx",
      skip_binary_upload: true,
      skip_metadata: true,
      overwrite_screenshots: true,
      screenshots_path: "./screenshots",
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Upload metadata to App Store Connect"
  lane :upload_metadata do
    deliver(
      api_key_path: API_KEY_PATH,
      platform: "osx",
      skip_binary_upload: true,
      skip_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Upload everything (metadata + screenshots) to App Store Connect"
  lane :upload_all do
    deliver(
      api_key_path: API_KEY_PATH,
      platform: "osx",
      skip_binary_upload: true,
      overwrite_screenshots: true,
      force: true,
      precheck_include_in_app_purchases: false,
    )
  end

  desc "Submit current version for App Store review"
  lane :submit_for_review do
    deliver(
      api_key_path: API_KEY_PATH,
      platform: "osx",
      skip_binary_upload: true,
      skip_screenshots: true,
      skip_metadata: true,
      submit_for_review: true,
      automatic_release: false,
      force: true,
      precheck_include_in_app_purchases: false,
      submission_information: {
        export_compliance_uses_encryption: true,
        export_compliance_is_exempt: true,
        add_id_info_uses_idfa: false,
        content_rights_has_rights: true,
        content_rights_contains_third_party_content: true,
      },
    )
  end
end
